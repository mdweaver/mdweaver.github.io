ds2000[, Peacekeeping := factor(untype4, levels = c(0,1), labels = c('No', 'Yes'))]
ggplot(ds2000, aes(x = treaty, y = develop, group = Peacekeeping, fill = Peacekeeping)) +
geom_point(alpha = 0.5) +
theme_bw() +
theme(legend.position="bottom")
ds2000[, Peacekeeping := factor(untype4, levels = c(0,1), labels = c('No', 'Yes'))]
ggplot(ds2000, aes(x = treaty, y = develop, group = Peacekeeping, fill = Peacekeeping)) +
geom_point(alpha = 0.5) +
#theme_bw() +
theme(legend.position="bottom")
ggplot(ds2000, aes(x = treaty, y = develop, group = Peacekeeping, fill = Peacekeeping, colour = Peacekeeping)) +
geom_point(alpha = 0.5) +
theme_bw() +
theme(legend.position="bottom")
names[ds2000]
names(ds2000)
require(GGally)
my_fn <- function(data, mapping, method="loess", ...){
p <- ggplot(data = data, mapping = mapping) +
geom_point() +
geom_smooth(method=method, ...)
p
}
ggpairs(ds2000[,10:1], lower = list(continuous = my_fn))
?ggpairs
require(GGally)
my_fn <- function(data, mapping, method="loess", ...){
p <- ggplot(data = data, mapping = mapping) +
geom_point() +
geom_smooth(method=method, ...)
p
}
gg1 = ggpairs(ds2000[,1:10], lower = list(continuous = my_fn))
gg1$plots = gg1$plots[1:19]
gg1$yAxisLabels = gg1$yAxisLabels[1:2]
gg1
