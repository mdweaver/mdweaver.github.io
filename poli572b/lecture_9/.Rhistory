y_bar = my_mean(data_1[[paste0('y',i)]]),
x_var = my_var(data_1[[paste0('x',i)]]),
y_var = my_var(data_1[[paste0('y',i)]]),
r_xy = my_cor(data_1[[paste0('x',i)]], data_1[[paste0('y',i)]])
)
) %>% rbindlist() %>%
kable()
require(knitr)
require(kableExtra)
require(magrittr)
require(data.table)
my_mean = function(x) {
return(sum(x)/length(x))
}
my_var = function(x) {
x2_bar = my_mean(x^2)
x_bar2 = my_mean(x)^2
return(x2_bar - x_bar2)
}
my_cor = function(x,y) {
xy_bar = my_mean(x*y)
x_bar_y_bar = my_mean(x) * my_mean(y)
cov_xy = xy_bar - x_bar_y_bar
var_x = my_var(x)
var_y = my_var(y)
return(cov_xy/(sqrt(var_x) * sqrt(var_y)))
}
lapply(1:4,
function(i)
data.frame(
group = i,
x_bar = my_mean(data_1[[paste0('x',i)]]),
y_bar = my_mean(data_1[[paste0('y',i)]]),
x_var = my_var(data_1[[paste0('x',i)]]),
y_var = my_var(data_1[[paste0('y',i)]]),
r_xy = my_cor(data_1[[paste0('x',i)]], data_1[[paste0('y',i)]])
)
) %>% rbindlist() %>%
kable() %>% kable_styling()
